# Managed by Ansible - do not edit manually
# SSH client hardening configuration

Host *
  # Strong ciphers only
  Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com,aes256-ctr,aes192-ctr,aes128-ctr

  # Strong MACs only (Encrypt-then-MAC)
  MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com

  # Strong KEX only
  KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group16-sha512,diffie-hellman-group18-sha512,diffie-hellman-group-exchange-sha256

  # Strong host key algorithms only
  HostKeyAlgorithms ssh-ed25519,ssh-ed25519-cert-v01@openssh.com,rsa-sha2-512,rsa-sha2-256

  # Disable password auth on client side
  PasswordAuthentication no

  # Disable agent and X11 forwarding
  ForwardAgent no
  ForwardX11 no

  # Hash known_hosts entries
  HashKnownHosts yes

  # Connection timeout
  ConnectTimeout 30

  # Disable roaming (CVE-2016-0777)
  UseRoaming no
